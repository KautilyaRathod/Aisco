# Copy to api/.env (not committed). Same variables can be set in Apache/httpd-vhosts if preferred.

APP_ENV=development

# URL path prefix for this app (must match how Apache exposes the API).
# Default: /api  → endpoints http://localhost/api/quote, etc.
# Subfolder example: /AISCO/api if the site is at http://localhost/AISCO/api/
API_PATH_PREFIX=/api

# MySQL (phpMyAdmin / XAMPP)
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=aisco

# CORS: production site origin, or leave empty to allow http://localhost:5173 in non-production
CLIENT_URL=

# SMTP (same as former Node backend)
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=
SMTP_USER=
SMTP_PASSWORD=
SMTP_RECIPIENT=
