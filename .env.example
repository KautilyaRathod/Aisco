# Server Configuration
PORT=4000
HOST=0.0.0.0
NODE_ENV=production

# Database Configuration (MySQL)
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=your_password_here
MYSQL_DATABASE=aisco

# Client URL (for CORS - your domain)
CLIENT_URL=https://yourdomain.com

# Optional: Serve static files from Express (set to 'true' if not using nginx for static files)
SERVE_STATIC=false

# Frontend API URL (optional - leave empty for relative paths with nginx proxy)
# VITE_API_URL=https://yourdomain.com
