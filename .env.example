# Frontend (Vite)
# Leave VITE_API_URL unset so the browser uses same-origin /api (dev server proxies to Apache).
# VITE_API_URL=http://localhost
# (no trailing slash — otherwise requests become //api/... and break)
#
# Where the Vite dev server forwards /api (Node only; default http://localhost). Not the same as VITE_API_URL.
# VITE_DEV_PROXY_TARGET=http://localhost
# If Apache serves API under a subfolder, rewrite /api/* to that prefix in dev.
# Example: /AISCO/api
# VITE_DEV_PROXY_API_PREFIX=/api

# App environment label (optional; PHP api/.env uses APP_ENV)
# NODE_ENV=production

# --- PHP API: copy api/.env.example to api/.env and configure MySQL + SMTP there.
# See api/README.md for Apache Alias, API_PATH_PREFIX, and XAMPP setup.
